#include <iostream>   // 用 cin / cout
#include <vector>     // 用 vector
#include <string>     // 用 string 存每一行地图
using namespace std;

int main() {
    // n 行，m 列
    int n, m;
    cin >> n >> m;

    // grid 表示整个矩阵
    // 每一行是一个字符串，比如 ".\/."
    vector<string> grid(n);

    // 读入 n 行地图
    for (int i = 0; i < n; i++) {
        cin >> grid[i];
    }

    // sx, sy 表示光线起点坐标
    // dir 表示光线初始方向
    // 0 上, 1 右, 2 下, 3 左
    int sx, sy, dir;
    cin >> sx >> sy >> dir;

    // cnt[i][j] 表示格子 (i, j) 被光经过了几次
    // 初始化为 0
    vector<vector<int>> cnt(n, vector<int>(m, 0));

    // vis[x][y][dir] 表示：
    // 光线是否曾经以方向 dir 进入过格子 (x, y)
    //
    // 为什么要记录方向？
    // 因为同一个格子，从不同方向进来，后续路线可能不同。
    // 但如果同一个格子 + 同一个方向再次出现，就说明进入循环了。
    vector<vector<vector<int>>> vis(
        n, vector<vector<int>>(m, vector<int>(4, 0))
    );

    // 方向数组
    // dir = 0，上：x - 1, y 不变
    // dir = 1，右：x 不变, y + 1
    // dir = 2，下：x + 1, y 不变
    // dir = 3，左：x 不变, y - 1
    int dx[4] = {-1, 0, 1, 0};
    int dy[4] = {0, 1, 0, -1};

    // 当前光线位置
    int x = sx, y = sy;

    // 只要光线还在矩阵里面，就继续模拟
    while (x >= 0 && x < n && y >= 0 && y < m) {

        // 如果同一个格子、同一个方向已经来过
        // 说明光线开始循环，继续走会无限循环，所以 break
        if (vis[x][y][dir]) break;

        // 标记这个状态来过了
        vis[x][y][dir] = 1;

        // 当前格子被光线经过一次
        cnt[x][y]++;

        // 如果当前格子是 / 镜子，改变方向
        //
        // 方向变化：
        // 上 -> 右
        // 右 -> 上
        // 下 -> 左
        // 左 -> 下
        if (grid[x][y] == '/') {
            if (dir == 0) dir = 1;
            else if (dir == 1) dir = 0;
            else if (dir == 2) dir = 3;
            else dir = 2;
        }

        // 如果当前格子是 \ 镜子，改变方向
        //
        // 注意：C++ 里反斜杠要写成 '\\'
        //
        // 方向变化：
        // 上 -> 左
        // 左 -> 上
        // 下 -> 右
        // 右 -> 下
        else if (grid[x][y] == '\\') {
            if (dir == 0) dir = 3;
            else if (dir == 3) dir = 0;
            else if (dir == 2) dir = 1;
            else dir = 2;
        }

        // 按照当前方向，往前走一格
        x += dx[dir];
        y += dy[dir];
    }

    // 输出每个格子被经过的次数
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cout << cnt[i][j] << " ";
        }
        cout << '\n';
    }

    return 0;
}
